# ============================================================
# NL2SQL-Local — .env.example
# Copier ce fichier en .env et remplir les valeurs
# AUCUNE clé API payante requise — stack 100% locale
# ============================================================

# --- Base de données PostgreSQL (via Docker Compose) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=demo_db
DB_USER=admin
DB_PASSWORD=admin123

# URL complète utilisée par SQLAlchemy
DATABASE_URL=postgresql://admin:admin123@localhost:5432/demo_db

# --- Ollama (LLM local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- ChromaDB (vector store local) ---
CHROMA_PERSIST_DIR=./chroma_db

# --- Langfuse (monitoring local, via Docker Compose) ---
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-local
LANGFUSE_SECRET_KEY=sk-local

# --- Paramètres du pipeline ---
MAX_CORRECTION_ATTEMPTS=3
SCHEMA_TOP_K=3
FEW_SHOT_TOP_K=3